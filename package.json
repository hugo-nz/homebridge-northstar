{
  "name": "homebridge-northstar",
  "version": "1.0.0",
  "description": "Northstar: Polestar connector for Homebridge",
  "license": "ISC",
  "homepage": "https://github.com/hugo-nz/homebridge-polestar",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/hugo-nz/homebridge-polestar.git"
  },
